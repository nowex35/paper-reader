# ── 解説（ローカルLLM） ──
# テキスト選択→解説 は Ollama で生成。クラウド送信なし・APIキー不要。
# 既定: qwen3.5:4b（ハイブリッド推論・~2.8GB、16GB Macで軽快）
# 高品質: qwen3:8b / 和訳の自然さ重視: gemma3:12b
OLLAMA_MODEL=qwen3.5:4b
OLLAMA_HOST=http://localhost:11434

# ── 質問機能（クラウドLLM・オプション） ──
# 論文全文を踏まえた質問ができる。未設定なら質問欄は非表示（解説はそのまま使える）。
# アプリ内の ⚙ 設定 からも変更可能。
#
# プロバイダ: gemini / openai / anthropic
ASK_PROVIDER=gemini
ASK_API_KEY=
ASK_MODEL=gemini-3.1-flash-lite
# OpenAI 互換エンドポイントを使う場合のみ（Groq, Together 等）
# ASK_BASE_URL=https://api.openai.com
